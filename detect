</footer>

<script>
  const BACKEND = 'https://api.traxe.co';
  const MAX_FREE = 3;
  let currentFile = null;
  let currentTab = 'url';

  // --- NAV ---
  function toggleMobileMenu() {
    document.getElementById('mobile-menu').classList.toggle('open');
    document.getElementById('nav-hamburger').classList.toggle('open');
  }

  // --- TABS ---
  function switchTab(tab) {
    currentTab = tab;
    document.getElementById('panel-url').style.display = tab === 'url' ? 'block' : 'none';
    document.getElementById('panel-file').style.display = tab === 'file' ? 'block' : 'none';
    document.getElementById('tab-url').className = 'scanner-tab' + (tab === 'url' ? ' active' : '');
    document.getElementById('tab-file').className = 'scanner-tab' + (tab === 'file' ? ' active' : '');
  }

  // --- FILE HANDLING ---
  function dragOver(e) { e.preventDefault(); document.getElementById('drop-zone').classList.add('drag'); }
  function dragLeave() { document.getElementById('drop-zone').classList.remove('drag'); }
  function dropFile(e) {
    e.preventDefault();
    dragLeave();
    const f = e.dataTransfer.files[0];
    if (f) setFile(f);
  }
  function fileSelected(e) { if (e.target.files[0]) setFile(e.target.files[0]); }
  function setFile(f) {
    currentFile = f;
    document.getElementById('drop-zone').style.display = 'none';
    const sel = document.getElementById('file-selected');
    sel.classList.add('show');
    document.getElementById('file-name').textContent = f.name;
    document.getElementById('file-size').textContent = (f.size / 1024 / 1024).toFixed(2) + ' MB';
  }
  function clearFile() {
    currentFile = null;
    document.getElementById('drop-zone').style.display = 'block';
    document.getElementById('file-selected').classList.remove('show');
    document.getElementById('file-input').value = '';
  }

  // --- FREE COUNTER ---
  function getChecksUsed() { return parseInt(localStorage.getItem('traxe_scans') || '0'); }
  function incrementChecks() { localStorage.setItem('traxe_scans', getChecksUsed() + 1); }
  function updateCounter() {
    const remaining = Math.max(0, MAX_FREE - getChecksUsed());
    const el = document.getElementById('free-counter');
    const txt = document.getElementById('counter-text');
    if (remaining === 0) { el.className = 'free-counter out'; txt.textContent = 'No free scans remaining — create account'; }
    else if (remaining === 1) { el.className = 'free-counter warn'; txt.textContent = '1 free scan remaining'; }
    else { el.className = 'free-counter'; txt.textContent = remaining + ' free scans remaining'; }
  }
  updateCounter();

  function showGate() { document.getElementById('gate').classList.add('show'); }
  function closeGate() { document.getElementById('gate').classList.remove('show'); }

  // --- SCAN ---
  async function runScan() {
    if (getChecksUsed() >= MAX_FREE) { showGate(); return; }

    const btn = document.getElementById('scan-btn');
    const btnText = document.getElementById('scan-btn-text');
    btn.disabled = true;
    btn.classList.add('loading');
    btnText.textContent = 'Scanning…';

    document.getElementById('results').classList.remove('show');

    try {
      let data;

      if (currentTab === 'url') {
        const url = document.getElementById('url-input').value.trim();
        if (!url) { alert('Please paste a URL first.'); return; }
        const resp = await fetch(BACKEND + '/detect', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url })
        });
        if (!resp.ok) { const e = await resp.json().catch(() => ({})); throw new Error(e.detail || 'Scan failed.'); }
        data = await resp.json();
      } else {
        if (!currentFile) { alert('Please select a file first.'); return; }
        const fd = new FormData();
        fd.append('file', currentFile);
        fd.append('declared_origin', 'unknown');
        // Use upload endpoint but scan-only flag
        const resp = await fetch(BACKEND + '/detect-file', {
          method: 'POST',
          body: fd
        });
        if (!resp.ok) { const e = await resp.json().catch(() => ({})); throw new Error(e.detail || 'Scan failed.'); }
        data = await resp.json();
      }

      incrementChecks();
      updateCounter();
      renderResults(data);

      if (getChecksUsed() >= MAX_FREE) setTimeout(showGate, 2500);

    } catch(e) {
      alert('Error: ' + e.message);
    } finally {
      btn.disabled = false;
      btn.classList.remove('loading');
      btnText.textContent = 'Scan Content';
    }
  }

  // --- RENDER RESULTS ---
  function renderResults(data) {
    const aiScore = Math.round((data.ai_score || 0) * 100);
    const verdict = data.verdict || (aiScore >= 70 ? 'AI GENERATED' : aiScore >= 40 ? 'UNCERTAIN' : 'REAL');
    const cls = verdict === 'AI GENERATED' ? 'ai' : verdict === 'UNCERTAIN' ? 'uncertain' : 'real';

    const descriptions = {
      'REAL': 'No significant AI generation signatures detected. Content appears to be of human or photographic origin.',
      'AI GENERATED': 'Strong AI generation signatures detected. This content was likely created or heavily modified by an AI tool.',
      'UNCERTAIN': 'Mixed signals detected. Content may be partially AI-generated, heavily edited, or the model confidence is low.'
    };

    document.getElementById('verdict-score').textContent = aiScore + '%';
    const badge = document.getElementById('verdict-badge');
    badge.className = 'verdict-badge ' + cls;
    badge.textContent = verdict;
    document.getElementById('verdict-desc').textContent = descriptions[verdict] || '';

    const bar = document.getElementById('conf-bar');
    bar.className = 'conf-bar-fill ' + cls;
    setTimeout(() => { bar.style.width = aiScore + '%'; }, 80);

    document.getElementById('scan-timestamp').textContent = new Date().toLocaleTimeString();

    // Metadata signals
    const signals = data.signals || {};
    const grid = document.getElementById('signals-grid');
    const items = [
      { label: 'EXIF Data', value: signals.has_exif === true ? 'Present' : signals.has_exif === false ? 'Missing' : 'N/A', cls: signals.has_exif === false ? 'warn' : 'ok' },
      { label: 'Camera Model', value: signals.camera_model || 'Not found', cls: signals.camera_model ? 'ok' : 'warn' },
      { label: 'Creation Software', value: signals.software || 'Unknown', cls: signals.software ? 'warn' : '' },
      { label: 'File Format', value: signals.format || data.content_type || 'Unknown', cls: '' },
      { label: 'Resolution', value: signals.resolution || 'Unknown', cls: '' },
      { label: 'AI Tool Detected', value: signals.ai_tool || 'None detected', cls: signals.ai_tool ? 'flag' : 'ok' },
    ];
    grid.innerHTML = items.map(i => `
      <div class="signal-item">
        <div class="signal-label">${i.label}</div>
        <div class="signal-value ${i.cls}">${i.value}</div>
      </div>`).join('');

    // Registry check
    const reg = document.getElementById('registry-result');
    if (data.registry_match) {
      reg.innerHTML = `<div class="registry-row found">
        <div class="registry-icon">✅</div>
        <div>
          <div class="registry-title">Registered in TRAXE Registry</div>
          <div class="registry-sub">This content has a verified certificate of origin.</div>
          <a href="${BACKEND}/verify/${data.registry_match}" target="_blank" class="registry-link">View Certificate → ${data.registry_match}</a>
        </div>
      </div>`;
    } else {
      reg.innerHTML = `<div class="registry-row not-found">
        <div class="registry-icon">🔍</div>
        <div>
          <div class="registry-title">Not found in TRAXE Registry</div>
          <div class="registry-sub">No certificate of origin found for this content. This does not confirm the content is fake.</div>
        </div>
      </div>`;
    }

    document.getElementById('results').classList.add('show');
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Pre-fill URL from query string
  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const preUrl = params.get('url');
    if (preUrl) {
      document.getElementById('url-input').value = preUrl;
      setTimeout(runScan, 400);
    }
  });
</script>
</body>
</html>
