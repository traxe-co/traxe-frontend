<div class="page">

  <div class="page-tag">Free AI Scanner</div>
  <h1 class="page-title">Is this content AI-generated?</h1>
  <p class="page-sub">Upload an image or video, or paste a URL. We analyse AI probability, metadata signals, and check if the content is registered in the TRAXE registry. No account needed for your first 3 scans.</p>

  <div class="free-counter" id="free-counter">
    <span class="counter-dot"></span>
    <span id="counter-text">3 free scans remaining</span>
  </div>

  <!-- SCANNER INPUT CARD -->
  <div class="scanner-card">
    <div class="scanner-tabs">
      <button class="scanner-tab active" id="tab-url" onclick="switchTab('url')">🔗 &nbsp;URL</button>
      <button class="scanner-tab" id="tab-file" onclick="switchTab('file')">📁 &nbsp;Upload File</button>
    </div>
    <div class="scanner-body">

      <!-- URL PANEL -->
      <div id="panel-url">
        <div class="url-row">
          <input class="url-input" id="url-input" type="url" placeholder="Paste any image or video URL…" autocomplete="off" onkeydown="if(event.key==='Enter')runScan()"/>
        </div>
        <p style="font-family:var(--mono);font-size:10px;color:var(--muted2);margin-top:10px;">Supports direct image/video URLs and most public web pages</p>
      </div>

      <!-- FILE PANEL -->
      <div id="panel-file" style="display:none;">
        <div class="drop-zone" id="drop-zone" onclick="document.getElementById('file-input').click()" ondragover="dragOver(event)" ondragleave="dragLeave(event)" ondrop="dropFile(event)">
          <span class="drop-zone-icon">⬆</span>
          <div class="drop-zone-title">Drop your file here or click to browse</div>
          <div class="drop-zone-sub">Images: JPG, PNG, WEBP, GIF · Videos: MP4, MOV, WEBM<br/>Max 50MB</div>
          <input type="file" id="file-input" accept="image/*,video/*" onchange="fileSelected(event)"/>
        </div>
        <div class="file-selected" id="file-selected">
          <span style="font-size:20px;">📄</span>
          <div class="file-name" id="file-name">filename.jpg</div>
          <div class="file-size" id="file-size">—</div>
          <button class="file-clear" onclick="clearFile()">✕</button>
        </div>
      </div>

      <button class="scan-btn" id="scan-btn" onclick="runScan()">
        <div class="spinner"></div>
        <span id="scan-btn-text">Scan Content</span>
      </button>
      <p class="scanner-hint">This scanner analyses content only. It does not create certificates. <a href="register.html" style="color:var(--blue-br);">Register content →</a> for a cryptographic certificate.</p>
    </div>
  </div>

  <!-- RESULTS -->
  <div class="results" id="results">

    <!-- AI PROBABILITY -->
    <div class="result-card">
      <div class="result-card-header">
        <span class="result-card-title">AI Detection</span>
        <span id="scan-timestamp" style="font-family:var(--mono);font-size:10px;color:var(--muted2);"></span>
      </div>
      <div class="result-card-body">
        <div class="verdict-row">
          <div class="verdict-score-wrap">
            <div class="verdict-score" id="verdict-score">—</div>
            <div class="verdict-score-label">AI probability</div>
          </div>
          <div class="verdict-badge" id="verdict-badge">—</div>
          <div class="verdict-desc" id="verdict-desc">—</div>
        </div>
        <div class="conf-bar-wrap">
          <div class="conf-bar-labels"><span>Human / Real</span><span>AI Generated</span></div>
          <div class="conf-bar-track"><div class="conf-bar-fill" id="conf-bar"></div></div>
        </div>
      </div>
    </div>

    <!-- METADATA SIGNALS -->
    <div class="result-card">
      <div class="result-card-header">
        <span class="result-card-title">Metadata Signals</span>
      </div>
      <div class="result-card-body">
        <div class="signals-grid" id="signals-grid">
          <!-- filled by JS -->
        </div>
      </div>
    </div>

    <!-- REGISTRY CHECK -->
    <div class="result-card">
      <div class="result-card-header">
        <span class="result-card-title">TRAXE Registry Check</span>
      </div>
      <div class="result-card-body">
        <div id="registry-result"></div>
        <div class="disclaimer">
          ⚠ This scan is an analysis tool only. Results are probabilistic — not legal proof. A negative registry result does not mean content is fake; it may simply not have been registered. For certified proof of origin, <a href="register.html" style="color:var(--blue-br);">register your content</a>.
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="result-cta">
      <div class="result-cta-text">
        <div class="result-cta-title">Certify your own content.</div>
        <div class="result-cta-sub">Register it with a cryptographic TRAXE ID — verifiable proof of origin.</div>
      </div>
      <a href="register.html" class="result-cta-btn">Register Content →</a>
    </div>

  </div>
</div>

<!-- GATE MODAL -->
<div class="gate" id="gate">
  <div class="gate-box">
    <div class="gate-icon">🔒</div>
    <div class="gate-title">You've used your 3 free scans</div>
    <div class="gate-sub">Create a free account to get 3 scans every month, or upgrade for unlimited access and white-label options.</div>
    <a href="register.html" class="gate-btn">Create Free Account →</a>
    <div class="gate-dismiss" onclick="closeGate()">Maybe later</div>
  </div>
</div>

